<ThemedPopup>:
    title_size: app.BUTTON_FONT_SIZE
    size_hint: (0.5, 0.75)
    separator_color: app.theme.detail

<BaseIpPopup>:
    size_hint_x: 0.5
    ThemedBoxLayout:
        orientation: "vertical"
        SingleRowLayout:
            CheckBoxLabel:
                text: _("IP Address:")
            ValueInput:
                id: ip_address_input
                text: root.ip_address.address
                on_focus: self.schedule_select_all() if self.focus else root.set_address(self)
                on_text_validate: root.on_okay()
        SingleRowLayout:
            CheckBoxLabel:
                text: _("Netmask:")
            ValueInput:
                id: netmask_input
                text: root.ip_address.netmask
                on_focus: self.schedule_select_all() if self.focus else root.set_netmask(self)
                on_text_validate: root.on_okay()
        SingleRowLayout:
            CheckBoxLabel:
                text: _("Gateway:")
            ValueInput:
                id: gateway_input
                text: root.ip_address.gateway
                on_focus: self.schedule_select_all() if self.focus else root.set_gateway(self)
                on_text_validate: root.on_okay()
        Widget:
        ActionPopupButtons:
            on_cancel: root.on_cancel()
            on_okay: root.on_okay()

<ChooseNicPopup>:
    size_hint_x: 0.5
    title: f"{self.device.hostname} | {_('Choose NIC')}"
    ThemedBoxLayout:
        orientation: "vertical"
        NICsRecView:
            id: nics_list
            size_hint_y: 0.8
            root: root
        ActionPopupButtons:
            on_cancel: root.on_cancel()
            on_okay: root.on_okay()

<CommandPopup>:
    title: _("Input command:")
    size_hint_y: 0.25
    ThemedBoxLayout:
        orientation: "vertical"
        ValueInput:
            id: text_input
            on_focus: self.schedule_select_all() if self.focus else None
            on_text_validate: root.on_okay()  # called when "Enter" is pressed
        ActionPopupButtons:  # cancel/okay
            on_cancel: root.on_cancel()
            on_okay: root.on_okay()

<DeviceCommandsPopup>:
    size_hint_x: 0.4

<EditDhcpPopup>:
    title: _("Edit DHCP configuration")
    size_hint_y: 0.5
    ThemedBoxLayout:
        orientation: "vertical"
        SingleRowLayout:
            size_hint_y: 0.2
            CheckBoxLabel:
                text: _("IP Address")
            CheckBoxLabel:
                text: _("Range Start")
            CheckBoxLabel:
                text: _("Range End")
        ThemedBoxLayout:
            padding: (dp(0), dp(0), dp(0), dp(0))
            size_hint_y: 0.2
            id: dhcp_configs_layout
            orientation: "vertical"
        Widget:
        ActionPopupButtons:
            on_cancel: root.on_cancel()
            on_okay: root.on_okay()

<EditFirewallPopup>:
    size_hint_x: 0.25
    title: _("Edit Firewall configuration")
    ThemedBoxLayout:
        orientation: "vertical"
        FirewallRulesRecView:
            id: firewall_rules_list
            root: root
        SingleRowLayout:
            ThemedButton:
                text: "+"
                id: add_button
                on_release: root.on_add_rule()
            ThemedButton:
                text: "-"
                id: remove_button
                on_release: root.on_remove_rule()
                disabled: True
            ThemedButton:
                text: _("Edit")
                id: edit_button
                on_release: root.on_edit_rule()
                disabled: True
        Widget:
        ActionPopupButtons:
            on_cancel: root.on_cancel()
            on_okay: root.on_okay()

<EditIpPopup>:
    title: _("Edit IP configuration")

<EditNicPopup>:
    size_hint_x: 0.5
    title: f"{_('Edit')} {self.device.hostname}:{self.nic.name}"
    ThemedBoxLayout:
        orientation: "vertical"
        SingleRowLayout:
            RightAlignedLabel:
                text: _("NIC type")
            CheckBoxLabel:
                text: root.nic.type
        SingleRowLayout:
            RightAlignedLabel:
                text: _("MAC address")
            CheckBoxLabel:
                text: root.nic.mac
        SingleRowLayout:
            Widget:
            SingleRowLayout:
                ThemedCheckBox:
                    size_hint_x: None
                    width: dp(30)
                    state: "down" if root.nic.can_use_dhcp else "normal"
                    disabled: True
                CheckBoxLabel:
                    text: _("Can use DHCP")
        SingleRowLayout:
            Widget:
            SingleRowLayout:
                ThemedCheckBox:
                    size_hint_x: None
                    width: dp(30)
                    state: "down" if root.nic.uses_dhcp else "normal"
                    on_active: root.on_uses_dhcp(self)
                CheckBoxLabel:
                    text: _("Uses DHCP")
        SingleRowLayout:
            RightAlignedLabel:
                text: _("VPN Endpoint")
            ValueInput:
                text: root.nic.endpoint
                on_focus: self.schedule_select_all() if self.focus else root.set_endpoint(self)
        SingleRowLayout:
            RightAlignedLabel:
                text: _("Encryption key")
            ValueInput:
                text: root.nic.encryption_key
                on_focus: self.schedule_select_all() if self.focus else root.set_encryption_key(self)
        Widget:
        ActionPopupButtons:
            on_cancel: root.on_cancel()
            on_okay: root.on_okay()

<EditRoutePopup>:
    title: f"{_('Edit route')} ({self.routes_popup.device.hostname})"

<EditRoutesPopup>:
    title: f"{_('Routes')} ({self.device.hostname})"
    size_hint: (0.5, 0.75)
    ThemedBoxLayout:
        orientation: "vertical"
        CheckBoxLabel:
            text: _("Routes from NICs (read-only)")
        RoutesRecView:
            id: nic_routes_list
            root: root
        CheckBoxLabel:
            text: _("Static routes (editable)")
        RoutesRecView:
            id: static_routes_list
            root: root
        SingleRowLayout:
            Widget:
                size_hint_x: 0.5
            ThemedButton:
                id: add_button
                size_hint_x: 0.125
                text: "+"
                on_release: root.on_add()
            ThemedButton:
                id: remove_button
                size_hint_x: 0.125
                text: "-"
                on_release: root.on_remove()
                disabled: True
            ThemedButton:
                id: edit_button
                size_hint_x: 0.25
                text: _("Edit")
                disabled: True
                on_release: root.on_edit()
        Widget:
            size_hint_y: 0.1
        ActionPopupButtons:
            on_cancel: root.on_cancel()
            on_okay: root.on_okay()

<ExceptionPopup>:
    title: _("Error")
    size_hint: (0.75, 0.75)
    ThemedBoxLayout:
        orientation: "vertical"
        ThemedScrollView:
            size_hint_y: 0.8
            TerminalLabel:
                id: exception
                padding: dp(3)
                size_hint: (None, None)
                text_size: (self.parent.parent.width, None)
                height: self.line_height * len(self.text.split("\n")) + dp(2)
                width: self.parent.parent.width - self.padding[1] - self.padding[3]

        HSeparator:
        PopupButton:
            pos_hint: {"center_x": 0.5}
            size_hint_x: 0.2
            text: _("Okay")
            on_release: root.dismiss()

<PingHostPopup>:
    size_hint: (0.5, 0.4)
    ThemedBoxLayout:
        orientation: "vertical"
        ValueInput:
            id: host
            hint_text: _("hostname or IP")
            on_focus: self.schedule_select_all() if self.focus else None
            on_text_validate: root.on_okay(root.ids.host.text)
        Widget:
        ActionPopupButtons:
            on_cancel: root.on_cancel()
            on_okay: root.on_okay(root.ids.host.text)

<PuzzleChooserPopup>:
    size_hint: (0.6, 1.0)
    title: _("Load Puzzle")
    ThemedBoxLayout:
        padding: dp(0)
        spacing: dp(0)
        canvas.before:
            Color:
                rgba: app.theme.bg2
            Rectangle:
                pos: self.pos
                size: self.size
        orientation: "vertical"
        ThemedBoxLayout:  # top section
            padding: dp(0)
            spacing: dp(0)
            size_hint_y: 0.9
            ThemedBoxLayout:
                orientation: "vertical"
                CheckBoxLabel:
                    text: _("Filter the puzzles by level:")
                SingleRowLayout:
                    FiltersCheckBox:
                        name: "Level0"
                    CheckBoxLabel:
                        text: _("Level 0")
                SingleRowLayout:
                    FiltersCheckBox:
                        name: "Level1"
                    CheckBoxLabel:
                        text: _("Level 1")
                SingleRowLayout:
                    FiltersCheckBox:
                        name: "Level2"
                    CheckBoxLabel:
                        text: _("Level 2")
                SingleRowLayout:
                    FiltersCheckBox:
                        name: "Level3"
                    CheckBoxLabel:
                        text: _("Level 3")
                SingleRowLayout:
                    FiltersCheckBox:
                        name: "Level4"
                    CheckBoxLabel:
                        text: _("Level 4")
                SingleRowLayout:
                    FiltersCheckBox:
                        name: "Level5"
                    CheckBoxLabel:
                        text: _("Level 5")
                SingleRowLayout:
                    FiltersCheckBox:
                        name: "Level6"
                    CheckBoxLabel:
                        text: _("Level 6")
                Widget: # spacer to keep other widgets at the top
            VSeparator:
            PuzzlesRecView:
                id: puzzles_view
        HSeparator:
        ActionPopupButtons:  # cancel/okay
            okay_text: _("Load")
            on_cancel: root.on_cancel()
            on_okay: root.on_load()


<PuzzleCompletePopup>:
    title: _("Puzzle complete!")
    size_hint_y: 0.5
    ThemedBoxLayout:
        orientation: "vertical"
        ThemedLabel:
            text: _("Congratulations, you have completed the puzzle!")
        ActionPopupButtons:  # cancel/okay
            on_cancel: root.on_cancel()
            on_okay: root.on_okay()
